# Example environment variables for TEAmate MVP
# Copy to .env and fill in values.

# Select provider(s): ollama | claude | openai
# Current intended MVP default: claude (Sonnet 4.6) when key is available.
LLM_PROVIDER=claude

# Claude (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=sonnet-4.6

# Motion (ticket/task creation)
MOTION_API_KEY=your_motion_api_key_here
# Optional identifiers depending on how Motion is configured in your workspace:
MOTION_WORKSPACE_ID=
MOTION_PROJECT_ID=

# Ollama (optional)
OLLAMA_HOST=http://localhost:11434

# OpenAI (optional)
OPENAI_API_KEY=your_openai_api_key_here

# Web (Next.js) wiring (optional; only needed once `web/` exists)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
