# Example environment variables for TEAmate MVP
# Copy to .env and fill in values.

# Select provider(s): ollama | claude | openai
LLM_PROVIDER=claude

# Claude (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=your_claude_model_name_here

# Ollama (optional)
OLLAMA_HOST=http://localhost:11434

# OpenAI (optional)
OPENAI_API_KEY=your_openai_api_key_here
