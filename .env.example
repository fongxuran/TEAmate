# Example environment variables for TEAmate MVP
# Copy to .env and fill in values.

# Select provider(s): ollama | claude | openai
# Current intended MVP default: claude (Sonnet 4.6) when key is available.
LLM_PROVIDER=claude

# Claude (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=sonnet-4.6

# Notion (ticket drafts -> pages)
NOTION_API_KEY=your_notion_api_key_here
# The database where TEAmate should create pages.
NOTION_DATABASE_ID=
# Name of the "title" property in your database (default: Name)
NOTION_TITLE_PROPERTY=Name
# Safety switch: defaults to true; set to false to create pages for real.
NOTION_DRY_RUN=true
# Optional override (useful for tests): default https://api.notion.com
NOTION_BASE_URL=
# Optional override (default: 2026-03-11)
NOTION_VERSION=

# Ollama (optional)
OLLAMA_HOST=http://localhost:11434

# OpenAI (optional)
OPENAI_API_KEY=your_openai_api_key_here

# Summary generation (optional)
# If set, controls where meeting summary cache entries are stored.
# Example: data/summary/meeting_summary.v1.jsonl
SUMMARY_CACHE_PATH=

# Web (Next.js) wiring (optional; only needed once `web/` exists)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# API (Go) local settings
# Basic auth is enabled by default in the API. Web proxies can use these values server-side.
API_BASIC_AUTH_USER=admin
API_BASIC_AUTH_PASS=password

# Set to true to disable auth for local experiments.
API_AUTH_DISABLED=false

# Comma-separated list of allowed origins for browser requests.
# Example: http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
