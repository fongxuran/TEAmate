# Use the Nexus proxy registry (see ../dreadnought/.npmrc for the reference setup).
registry=https://nexus.in.spdigital.sg/repository/npm-all

# Some environments set a scoped registry for @types in user-level config.
# Pin it here so `npm install` is consistent for @types/node, @types/react, etc.
@types:registry=https://nexus.in.spdigital.sg/repository/npm-all
