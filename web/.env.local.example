# Next.js local dev env
# Copy to .env.local

# Public wiring (used by browser code if/when we add direct calls / WebSockets)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# Server-side proxy auth to the Go API (not exposed to the browser)
API_BASIC_AUTH_USER=admin
API_BASIC_AUTH_PASS=password

# Optional override if API runs elsewhere
API_BASE_URL=http://localhost:8080
